# VLM backend: "claude" | "internvl" | "llava"
VLM_BACKEND=claude

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Local VLM (only needed if VLM_BACKEND=internvl or llava)
# LOCAL_VLM_MODEL=InternVL2-8B
# LOCAL_VLM_DEVICE=cuda

# Tesseract path (if not on PATH)
# TESSERACT_CMD=/usr/bin/tesseract
OCR_DPI=300

# Validation
TOTAL_TOLERANCE=0.01
FUZZY_VENDOR_THRESHOLD=80
MAX_CORRECTION_ATTEMPTS=2

# Storage
SQLITE_PATH=./data/invoices.db
CHROMA_PERSIST_DIR=./data/chroma
